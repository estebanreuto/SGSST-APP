        .alert{padding:11px 14px;border-radius:8px;margin-bottom:16px;display:flex;align-items:center;gap:9px;font-weight:650}.alert.ok{background:#ecfdf5;color:#166534;border:1px solid #bbf7d0}.alert.error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}.pending-banner{padding:12px 15px;border-radius:8px;background:#fff7ed;border:1px solid #fed7aa;color:#9a3412;margin-bottom:16px;display:flex;justify-content:space-between;align-items:center;gap:12px}
        .summary-grid{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:12px;margin-bottom:12px}.summary-card{--metric-color:#1e3a8a;--metric-soft:#eef4ff;position:relative;overflow:hidden;background:#fff;border:1px solid var(--border);border-radius:8px;padding:14px;min-height:150px;min-width:0;display:flex;flex-direction:column;gap:8px;box-shadow:0 5px 16px rgba(15,23,42,.04);transition:transform .22s ease,box-shadow .22s ease,border-color .22s ease}.summary-card:hover{transform:translateY(-2px);box-shadow:0 12px 26px rgba(15,23,42,.08);border-color:#cbd5e1}.summary-card.metric-blue{--metric-color:#1e3a8a;--metric-soft:#eef4ff}.summary-card.metric-orange{--metric-color:#f58220;--metric-soft:#fff3e8}.summary-card.metric-green{--metric-color:#16a34a;--metric-soft:#ecfdf5}.summary-card.metric-amber{--metric-color:#d97706;--metric-soft:#fff7ed}.summary-card.metric-red{--metric-color:#dc2626;--metric-soft:#fef2f2}.summary-card.metric-violet{--metric-color:#635bff;--metric-soft:#f0efff}.summary-top{position:relative;z-index:1;display:flex;align-items:flex-start;justify-content:space-between;gap:10px}.summary-icon{width:43px;height:43px;border-radius:10px;display:grid;place-items:center;flex:none;color:var(--metric-color);background:var(--metric-soft);font-size:1rem}.summary-value{font-size:1.65rem;font-weight:850;line-height:1;color:var(--metric-color);letter-spacing:0}.summary-title{position:relative;z-index:1;margin-top:5px;color:var(--blue-dark);font-size:.84rem;line-height:1.18;font-weight:850}.summary-card p{position:relative;z-index:1;margin:0;color:var(--muted);font-size:.66rem;line-height:1.35}.summary-period{position:relative;z-index:1;margin-top:auto;display:flex;align-items:center;gap:7px;color:#94a3b8;font-size:.64rem;font-weight:800}.summary-period i{font-size:.62rem}.summary-watermark{position:absolute;right:-15px;bottom:-20px;color:var(--metric-color);font-size:4.9rem;line-height:1;opacity:.055;transform:rotate(-12deg);transition:transform .28