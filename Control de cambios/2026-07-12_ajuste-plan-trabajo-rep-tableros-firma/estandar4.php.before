<body>
<?php include 'components/sidebar.php'; ?>
<main class="main-wrapper">
    <?php include 'components/header.php'; ?>
    <div class="content-area">
        <div class="page-head">
            <div class="head-copy">
                <div class="head-icon"><i class="fa-solid fa-clipboard-check"></i></div>
                <div>
                    <h1>4. Plan Anual de Trabajo</h1>
                    <p>Programa, ejecuta y documenta las actividades del SG-SST durante la vigencia.</p>
                </div>
            </div>
            <div class="head-actions">
                <span class="status-plan <?php echo $estado_plan[1]; ?>"><?php echo $estado_plan[0]; ?></span>
                <label class="year-filter">
                    <span><i class="fa-regular fa-calendar"></i> Vigencia</span>
                    <div class="year-select-wrap">
                        <select class="year-select" onchange="location.href='estandar4.php?anio='+this.value" aria-label="Seleccionar vigencia">
                            <?php for ($y = (int)date('Y') + 1; $y >= (int)date('Y') - 4; $y--): ?>
                                <option value="<?php echo $y; ?>" <?php echo $y === $anio ? 'selected' : ''; ?>><?php echo $y; ?></option>
                            <?php endfor; ?>
                        </select>
                        <i class="fa-solid fa-chevron-down"></i>
                    </div>
                </label>
                <?php if ($editable): ?>
                    <button class="btn btn-primary" type="button" onclick="openActivityModal()"><i class="fa-solid fa-plus"></i> Nueva actividad</button>
                <?php endif; ?>
            </div>
        </div>

        <?php if (isset($_GET['msg'])): ?>
            <div class="alert <?php echo ($_GET['tipo'] ?? '') === 'error' ? 'error' : 'ok'; ?>">
                <i class="fa-solid <?php echo ($_GET['tipo'] ?? '') === 'error' ? 'fa-circle-exclamation' : 'fa-circle-check'; ?>"></i>
                <?php echo htmlspecialchars($_GET['msg']); ?>
            </div>
        <?php endif; ?>

        <?php if ($usuario_rol === 'representante' && $plan['estado'] === 'pendiente_firma'): ?>
            <div class="pending-banner">
                <div><strong>El plan anual está listo para tu revisión.</strong><br>Verifica la programación y firma al final del documento.</div>
                <i class="fa-solid fa-file-signature"></i>
            </div>
        <?php endif; ?>

        <div class="summary-grid">
            <article class="summary-card metric-orange">
                <div class="summary-watermark"><i class="fa-solid fa-list-check"></i></div>
                <div class="summary-top"><div class="summary-icon"><i class="fa-solid fa-list-check"></i></div><div class="summary-value"><?php echo count($actividades); ?></div></div>
                <div class="summary-title">Total Actividades</div>
                <p>Histórico global del plan SG-SST.</p>
                <button class="summary-period" type="button" data-summary-toggle aria-expanded="false"><?php echo $resumen_periodo; ?> <i class="fa-solid fa-chevron-down"></i></button>
                <div class="summary-month-panel" aria-hidden="true"><span><strong><?php echo $total_mes_inicial; ?></strong>Mes</span><span><strong><?php echo count($actividades); ?></strong>Total</span></div>
            </article>
            <article class="summary-card metric-blue">
                <div class="summary-watermark"><i class="fa-regular fa-calendar-days"></i></div>
                <div class="summary-top"><div class="summary-icon"><i class="fa-regular fa-calendar-days"></i></div><div class="summary-value"><?php echo $metricas['programadas']; ?></div></div>
                <div class="summary-title">Programadas</div>
                <p>Pendientes por realizar durante la vigencia.</p>
                <button class="summary-period" type="button" data-summary-toggle aria-expanded="false"><?php echo $resumen_periodo; ?> <i class="fa-solid fa-chevron-down"></i></button>
                <div class="summary-month-panel" aria-hidden="true"><span><strong><?php echo $indicador_inicial['P']; ?></strong>Mes</span><span><strong><?php echo $metricas['programadas']; ?></strong>Pend.</span></div>
            </article>
            <article class="summary-card metric-green">
                <div class="summary-watermark"><i class="fa-solid fa-check-double"></i></div>
                <div class="summary-top"><div class="summary-icon"><i class="fa-solid fa-check-double"></i></div><div class="summary-value"><?php echo $metricas['ejecutadas']; ?></div></div>
                <div class="summary-title">Ejecutadas</div>
                <p>Finalizadas con evidencia registrada.</p>
                <button class="summary-period" type="button" data-summary-toggle aria-expanded="false"><?php echo $resumen_periodo; ?> <i class="fa-solid fa-chevron-down"></i></button>
                <div class="summary-month-panel" aria-hidden="true"><span><strong><?php echo $indicador_inicial['E']; ?></strong>Mes</span><span><strong><?php echo $metricas['ejecutadas']; ?></strong>Hechas</span></div>
            </article>
            <article class="summary-card metric-amber">
                <div class="summary-watermark"><i class="fa-solid fa-clock-rotate-left"></i></div>
                <div class="summary-top"><div class="summary-icon"><i class="fa-solid fa-clock-rotate-left"></i></div><div class="summary-value"><?php echo $metricas['reprogramadas']; ?></div></div>
                <div class="summary-title">Reprogramadas</div>
                <p>Actividades ajustadas de fecha.</p>
                <button class="summary-period" type="button" data-summary-toggle aria-expanded="false"><?php echo $resumen_periodo; ?> <i class="fa-solid fa-chevron-down"></i></button>
                <div class="summary-month-panel" aria-hidden="true"><span><strong><?php echo $indicador_inicial['R']; ?></strong>Mes</span><span><strong><?php echo $metricas['reprogramadas']; ?></strong>Ajust.</span></div>
            </article>
            <article class="summary-card metric-red">
                <div class="summary-watermark"><i class="fa-regular fa-calendar-xmark"></i></div>
                <div class="summary-top"><div class="summary-icon"><i class="fa-regular fa-calendar-xmark"></i></div><div class="summary-value"><?php echo $no_ejecutadas; ?></div></div>
                <div class="summary-title">No Ejecutadas</div>
                <p>Programaciones vencidas sin ejecución.</p>
                <button class="summary-period" type="button" data-summary-toggle aria-expanded="false"><?php echo $resumen_periodo; ?> <i class="fa-solid fa-chevron-down"></i></button>
                <div class="summary-month-panel" aria-hidden="true"><span><strong><?php echo $no_ejecutadas_mes; ?></strong>Mes</span><span><strong><?php echo $no_ejecutadas; ?></strong>Venc.</span></div>
            </article>
            <article class="summary-card metric-violet">
                <div class="summary-watermark"><i class="fa-solid fa-chart-line"></i></div>
                <div class="summary-top"><div class="summary-icon"><i class="fa-solid fa-chart-line"></i></div><div class="summary-value"><?php echo $metricas['cumplimiento']; ?>%</div></div>
                <div class="summary-title">Efectividad Global</div>
                <p><?php echo $cumple_meta ? 'Meta anual alcanzada.' : 'Avance frente a la meta anual.'; ?></p>
                <button class="summary-period" type="button" data-summary-toggle aria-expanded="false"><?php echo $resumen_periodo; ?> <i class="fa-solid fa-chevron-down"></i></button>
                <div class="summary-month-panel" aria-hidden="true"><span><strong><?php echo $porcentaje_mes_inicial; ?>%</strong>Mes</span><span><strong><?php echo $metricas['cumplimiento']; ?>%</strong>Año</span></div>
            </article>
        </div>

        <section class="control-panel">
            <div class="control-top">
                <div><h2>Indicadores automáticos</h2><div class="cell-muted">Medición anual entre actividades programadas, ejecutadas y reprogramadas.</div></div>
                <form class="meta-form" action="procesar_estandar4.php" method="post">
                    <input type="hidden" name="accion" value="guardar_meta"><input type="hidden" name="anio" value="<?php echo $anio; ?>">
                    <label class="meta-label" for="meta"><i class="fa-solid fa-bullseye"></i> Meta anual</label>
                    <div class="meta-input-wrap">
                        <input id="meta" name="meta_cumplimiento" type="number" min="1" max="100" value="<?php echo $meta; ?>" <?php echo !$editable ? 'disabled' : ''; ?>>
                        <span class="meta-suffix">%</span>
                    </div>
                    <?php if ($editable): ?><button class="icon-btn" title="Guardar meta"><i class="fa-solid fa-check"></i></button><?php endif; ?>
                </form>
            </div>
            <div class="progress-track"><div class="progress-fill" style="width:<?php echo min(100, $metricas['cumplimiento']); ?>%"></div></div>
            <div class="compliance-grid">
                <article class="compliance-card" style="--metric-soft:#fff3e8">
                    <h3>Cumplimiento actual</h3>
                    <p>Avance acumulado frente a las actividades del plan.</p>
                    <div class="compliance-donut-wrap">
                        <div class="compliance-donut" style="--value:<?php echo min(100, $metricas['cumplimiento']); ?>"></div>
                        <div class="donut-center"><?php echo $metricas['cumplimiento']; ?>%</div>
                        <div class="compliance-legend">
                            <div class="legend-row"><i class="legend-mark"></i> Cumplido <strong><?php echo $metricas['cumplimiento']; ?>%</strong></div>
                            <div class="legend-row"><i class="legend-mark missing"></i> Falta a 100% <strong><?php echo $faltante_total; ?>%</strong></div>
                            <div class="legend-row"><i class="legend-mark goal"></i> Meta anual <strong><?php echo $meta; ?>%</strong></div>
                        </div>
                    </div>
                </article>
                <article class="compliance-card" style="--metric-soft:#ecfdf5">
                    <h3>Camino hacia la meta</h3>
                    <p>Lo que llevas frente a la meta definida para esta vigencia.</p>
                    <div class="goal-track" style="--goal-progress:<?php echo $avance_sobre_meta; ?>%;--goal-target:100%">
                        <div class="goal-line"><div class="goal-fill"></div></div>
                        <div class="goal-marker" title="Meta <?php echo $meta; ?>%"></div>
                        <div class="goal-labels"><span>0%</span><span>Meta <?php echo $meta; ?>%</span><span>100%</span></div>
                    </div>
                    <div class="goal-note">
                        <span><strong><?php echo $avance_sobre_meta; ?>%</strong>de la meta</span>
                        <span><strong><?php echo $faltante_meta; ?> pts</strong>faltan</span>
                        <span><strong><?php echo $ejecuciones_para_meta; ?></strong>ejecuciones</span>
                    </div>
                </article>
                <article class="compliance-card" style="--metric-soft:#eef4ff">
                    <h3>Distribución del plan</h3>
                    <p>Estado de las actividades que alimentan el indicador anual.</p>
                    <div class="mini-bars">
                        <div class="mini-bar-row"><span>Programadas</span><div class="mini-bar-track"><div class="mini-bar-fill" style="--bar-width:<?php echo round(($metricas['programadas'] / $base_grafica) * 100); ?>%;--bar-color:#1e3a8a"></div></div><strong><?php echo $metricas['programadas']; ?></strong></div>
                        <div class="mini-bar-row"><span>Ejecutadas</span><div class="mini-bar-track"><div class="mini-bar-fill" style="--bar-width:<?php echo round(($metricas['ejecutadas'] / $base_grafica) * 100); ?>%;--bar-color:#16a34a"></div></div><strong><?php echo $metricas['ejecutadas']; ?></strong></div>
                        <div class="mini-bar-row"><span>Reprogramadas</span><div class="mini-bar-track"><div class="mini-bar-fill" style="--bar-width:<?php echo round(($metricas['reprogramadas'] / $base_grafica) * 100); ?>%;--bar-color:#d97706"></div></div><strong><?php echo $metricas['reprogramadas']; ?></strong></div>
