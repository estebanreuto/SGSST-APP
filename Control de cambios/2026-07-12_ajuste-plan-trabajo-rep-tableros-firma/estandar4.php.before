        .summary-month-panel{grid-template-columns:repeat(4,max-content);justify-content:flex-start;align-items:center;gap:12px}.summary-card.is-open .summary-month-panel{max-height:42px;margin-top:0}.summary-month-panel span{border:0;background:transparent;border-radius:0;padding:0;display:flex;align-items:baseline;gap:3px;color:#94a3b8;font-size:.58rem;text-align:left}.summary-month-panel strong{display:inline;color:var(--metric-color);font-size:.95rem;line-height:1;margin:0}.plan-month-grid{gap:0 16px}.plan-month{border:0;background:transparent;border-radius:0;padding:8px 0 10px;border-bottom:1px solid #eef2f7}.plan-month-name{margin-bottom:6px}.plan-month-state{background:transparent;padding:0;color:#94a3b8}.month-toggle{justify-content:flex-start;gap:6px}.month-toggle form{width:24px;height:24px;flex:0 0 24px}.month-state{width:24px;height:24px;border:0;background:#f8fafc;border-radius:6px;box-shadow:none;color:#64748b;font-size:.62rem}.month-state:hover{background:#fff7ed;border-color:transparent;color:var(--primary2);box-shadow:none}.month-state.p.active,.month-state.e.active,.month-state.r.active{box-shadow:none;color:#fff}.month-date{text-align:left;margin-top:5px}@media(max-width:768px){.summary-month-panel{grid-template-columns:repeat(4,max-content);gap:10px}.plan-month-grid{gap:0 12px}}
        .compliance-grid{display:grid;grid-template-columns:260px minmax(260px,1fr) minmax(260px,.9fr);gap:12px;margin-top:12px}.compliance-card{position:relative;overflow:hidden;border:1px solid var(--border);border-radius:8px;background:#fff;padding:14px;min-height:168px;box-shadow:0 5px 16px rgba(15,23,42,.035)}.compliance-card h3{margin:0;color:var(--blue-dark);font-size:.78rem}.compliance-card p{margin:4px 0 0;color:var(--muted);font-size:.64rem;line-height:1.35}.compliance-card::after{content:"";position:absolute;right:-24px;bottom:-28px;width:120px;height:120px;border-radius:50%;background:var(--metric-soft,#fff3e8);opacity:.55}.compliance-donut-wrap{position:relative;z-index:1;display:flex;align-items:center;gap:14px;margin-top:14px}.compliance-donut{--value:0;width:102px;height:102px;border-radius:50%;background:conic-gradient(var(--primary2) calc(var(--value)*1%),#e2e8f0 0);display:grid;place-items:center;flex:none}.compliance-donut::before{content:"";width:72px;height:72px;border-radius:50%;background:#fff;box-shadow:inset 0 0 0 1px #eef2f7}.donut-center{position:absolute;left:0;width:102px;text-align:center;color:var(--blue-dark);font-size:1.18rem;font-weight:850}.compliance-legend{display:grid;gap:7px;min-width:0}.legend-row{display:flex;align-items:center;gap:7px;color:#64748b;font-size:.64rem;font-weight:750}.legend-row strong{margin-left:auto;color:#172554}.legend-mark{width:8px;height:8px;border-radius:2px;background:var(--primary2);flex:none}.legend-mark.missing{background:#cbd5e1}.legend-mark.goal{background:#22c55e}.goal-track{position:relative;z-index:1;margin-top:17px}.goal-line{height:12px;border-radius:99px;background:#e2e8f0;overflow:hidden}.goal-fill{height:100%;width:var(--goal-progress);background:linear-gradient(90deg,#f97316,#22c55e);border-radius:inherit}.goal-marker{position:absolute;top:-5px;left:calc(var(--goal-target) - 1px);width:2px;height:22px;background:#172554;border-radius:2px}.goal-labels{display:flex;justify-content:space-between;margin-top:8px;color:#64748b;font-size:.6rem;font-weight:800}.goal-note{position:relative;z-index:1;display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:13px}.goal-note span{border:1px solid #eef2f7;background:#f8fafc;border-radius:7px;padding:8px;color:#64748b;font-size:.58rem;font-weight:800}.goal-note strong{display:block;color:#172554;font-size:1rem;margin-bottom:2px}.mini-bars{position:relative;z-index:1;display:grid;gap:9px;margin-top:14px}.mini-bar-row{display:grid;grid-template-columns:92px 1fr 34px;gap:8px;align-items:center;color:#64748b;font-size:.62rem;font-weight:800}.mini-bar-track{height:9px;background:#edf2f7;border-radius:99px;overflow:hidden}.mini-bar-fill{height:100%;width:var(--bar-width);background:var(--bar-color);border-radius:inherit}.compliance-foot{position:relative;z-index:1;margin-top:12px;display:flex;align-items:center;gap:8px;color:#475569;font-size:.66rem;font-weight:800}.compliance-foot i{color:var(--primary2)}@media(max-width:1200px){.compliance-grid{grid-template-columns:1fr 1fr}.compliance-grid .compliance-card:first-child{grid-column:1/-1}}@media(max-width:768px){.compliance-grid{grid-template-columns:1fr}.goal-note{grid-template-columns:1fr}.mini-bar-row{grid-template-columns:82px 1fr 28px}}
