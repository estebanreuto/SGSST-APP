play:flex;align-items:flex-start;justify-content:space-between;gap:12px}.month-card-title span{display:block;color:rgba(255,255,255,.68);font-size:.62rem;font-weight:800;text-transform:uppercase;margin-bottom:4px}.month-card-title strong{font-size:1.05rem}.month-percent{font-size:2.1rem;line-height:1;font-weight:800}.month-percent small{font-size:.7rem;color:rgba(255,255,255,.72);font-weight:700}.month-bars{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:16px}.month-pill{background:rgba(255,255,255,.11);border:1px solid rgba(255,255,255,.14);border-radius:7px;padding:8px}.month-pill span{display:block;font-size:.56rem;color:rgba(255,255,255,.68);text-transform:uppercase;font-weight:800}.month-pill strong{display:block;margin-top:2px;font-size:1rem}.month-selector-card{border:1px solid var(--border);border-radius:8px;background:#f8fafc;padding:13px;display:flex;flex-direction:column;justify-content:space-between;gap:10px}.month-select-label{display:flex;align-items:center;gap:8px;color:#334155;font-size:.68rem;font-weight:800;text-transform:uppercase}.month-select-label i{color:var(--primary2)}.month-select-wrap{position:relative}.month-select-wrap select{width:100%;height:40px;border:1px solid var(--border);border-radius:8px;background:#fff;padding:0 34px 0 12px;color:#1e293b;font-weight:750;appearance:none;outline:0}.month-select-wrap i{position:absolute;right:12px;top:50%;transform:translateY(-50%);color:#94a3b8;pointer-events:none}.month-select-wrap select:focus{border-color:#fdba74;box-shadow:0 0 0 3px rgba(251,146,60,.12)}.legend-months{display:flex;gap:8px;flex-wrap:wrap;color:var(--muted);font-size:.65rem}.legend-dot{width:7px;height:7px;border-radius:2px;display:inline-block;margin-right:4px}.dot-p{background:#818cf8}.dot-e{background:#22c55e}.dot-r{background:#f59e0b}
        .section{background:#fff;border:1px solid var(--border);border-radius:8px;margin-top:12px;overflow:hidden}.section-head{padding:12px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:12px}.section-head h2{margin:0;color:var(--blue-dark);font-size:.88rem}.section-head p{margin:3px 0 0;color:var(--muted);font-size:.68rem}.cell-title{font-weight:700;color:#1e293b}.cell-muted{color:var(--muted);font-size:.65rem;margin-top:3px}.plan-cards{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;padding:14px;background:#f8fafc}.plan-card{--plan-bg:#1e3a8a;--plan-accent:#38bdf8;background:#fff;border:1px solid var(--border);border-radius:8px;overflow:hidden;min-width:0;box-shadow:0 5px 16px rgba(15,23,42,.04);transition:transform .22s ease,box-shadow .22s ease,border-color .22s ease}.plan-card:hover{transform:translateY(-2px);box-shadow:0 12px 26px rgba(15,23,42,.08);border-color:#cbd5e1}.plan-card-head{position:relative;overflow:hidden;background:var(--plan-bg);color:#fff;min-height:118px;padding:13px 13px 13px 18px;display:flex;flex-direction:column;justify-content:space-between}.plan-card-head::before{content:"";position:absolute;width:46%;height:120%;right:-14%;top:-10%;background:rgba(255,255,255,.1);transform:skewX(-13deg)}.plan-card-head::after{content:"";position:absolute;width:5px;height:58%;left:13px;bottom:13px;background:var(--plan-accent);border-radius:4px}.plan-card.theme-orange{--plan-bg:#c2410c;--plan-accent:#fed7aa}.plan-card.theme-green{--plan-bg:#166534;--plan-accent:#86efac}.plan-card.theme-violet{--plan-bg:#5b21b6;--plan-accent:#c4b5fd}.plan-card.theme-teal{--plan-bg:#0f766e;--plan-accent:#2dd4bf}.plan-card-top,.plan-card-main,.plan-card-foot{position:relative;z-index:1}.plan-card-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px}.plan-topic{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.12);border:1px solid rgba(255,25