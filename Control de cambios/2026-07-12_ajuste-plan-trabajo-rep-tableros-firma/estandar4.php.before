    <?php foreach ($responsables as $responsable): ?><option value="<?php echo htmlspecialchars(trim($responsable['nombre'] . ' ' . $responsable['apellido'])); ?>"><?php echo htmlspecialchars(ucfirst($responsable['rol'])); ?></option><?php endforeach; ?>
