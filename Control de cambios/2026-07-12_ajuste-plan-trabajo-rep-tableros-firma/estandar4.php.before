                                    data-r="<?php echo $m['R']; ?>"
                                    data-percent="<?php echo $porcentaje_mes; ?>"
                                    <?php echo $numero === $mes_indicador ? 'selected' : ''; ?>>
                                    <?php echo $meses_completos[$numero]; ?> · <?php echo $porcentaje_mes; ?>%
                                </option>
