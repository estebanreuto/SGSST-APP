                                                    <td><?php echo (int)$item['cantidad']; ?></td>
                                                    <td><?php echo htmlspecialchars((string)$item['porcentaje']); ?>%</td>
                                                    <td><?php echo (int)$item['cantidad']; ?> de <?php echo $stat['total']; ?> trabajador(es)</td>
                                                </tr>
                                            <?php endforeach; ?>
                                        </tbody>
                                    </table>
                                </div>
                            </article>
